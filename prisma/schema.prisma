generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  NEW
  PAID
  ASSEMBLING
  SHIPPED
  DELIVERED
  CANCELED
  RETURNED
}

enum ReviewSource {
  SITE
  OZON
  WILDBERRIES
  YANDEX_MARKET
  OTHER
}

enum ReviewStatus {
  NEW
  PENDING_REPLY
  REPLIED
  ARCHIVED
}

enum DeliveryMethodType {
  CDEK
  BOXBERRY
  POST_RU
  COURIER
  PICKUP
  OTHER
}

enum ShopStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum ShopDomainType {
  PREVIEW
  CUSTOM
}

enum DomainVerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

enum TaxonomySource {
  MARKETPLACE
  OZON
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Shop {
  id                 String     @id @default(cuid())
  name               String
  slug               String     @unique
  previewSubdomain   String     @unique
  status             ShopStatus @default(DRAFT)
  isPreviewProtected Boolean    @default(true)
  previewAccessToken String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  domains        ShopDomain[]
  products       Product[]
  siteCategories SiteCategory[]
  siteThemes     SiteTheme[]
  siteBanners    SiteBanner[]
}

model ShopDomain {
  id                 String                   @id @default(cuid())
  shopId             String
  host               String                   @unique
  type               ShopDomainType
  isPrimary          Boolean                  @default(false)
  verificationStatus DomainVerificationStatus @default(PENDING)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, type])
}

model MarketplaceTaxonomyMeta {
  id              String         @id @default(cuid())
  source          TaxonomySource @unique
  taxonomyVersion Int            @default(1)
  checksum        String?
  syncedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model MarketplaceCategory {
  id         String         @id @default(cuid())
  source     TaxonomySource
  externalId String
  parentId   String?
  title      String
  fullPath   String?
  level      Int            @default(0)
  isLeaf     Boolean        @default(false)
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  parent               MarketplaceCategory?  @relation("MarketplaceCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children             MarketplaceCategory[] @relation("MarketplaceCategoryTree")
  mappedSiteCategories SiteCategory[]
  products             Product[]

  @@unique([source, externalId])
  @@index([source, parentId])
  @@index([source, title])
}

model SiteCategory {
  id                          String   @id @default(cuid())
  shopId                      String
  parentId                    String?
  mappedMarketplaceCategoryId String?
  title                       String
  slug                        String
  description                 String?
  imageUrl                    String?
  imageAlt                    String?
  imageTitle                  String?
  seoTitle                    String?
  seoDescription              String?
  sortOrder                   Int      @default(0)
  isVisible                   Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  shop                      Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  parent                    SiteCategory?        @relation("SiteCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children                  SiteCategory[]       @relation("SiteCategoryTree")
  mappedMarketplaceCategory MarketplaceCategory? @relation(fields: [mappedMarketplaceCategoryId], references: [id], onDelete: SetNull)
  products                  Product[]

  @@unique([shopId, slug])
  @@index([shopId, parentId, sortOrder])
  @@index([mappedMarketplaceCategoryId])
}

model Product {
  id                    String        @id @default(cuid())
  shopId                String
  siteCategoryId        String?
  marketplaceCategoryId String?
  sku                   String
  slug                  String
  title                 String
  shortDescription      String?
  description           String?
  category              String?
  brand                 String        @default("KaiRox")
  status                ProductStatus @default(DRAFT)
  price                 Decimal       @db.Decimal(10, 2)
  compareAtPrice        Decimal?      @db.Decimal(10, 2)
  purchasePrice         Decimal?      @db.Decimal(10, 2)
  currency              String        @default("RUB")
  stock                 Int           @default(0)
  reservedStock         Int           @default(0)
  seoTitle              String?
  seoDescription        String?
  attributesJson        Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  shop                Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  siteCategory        SiteCategory?        @relation(fields: [siteCategoryId], references: [id], onDelete: SetNull)
  marketplaceCategory MarketplaceCategory? @relation(fields: [marketplaceCategoryId], references: [id], onDelete: SetNull)
  images              ProductImage[]
  reviews             Review[]
  orderItems          OrderItem[]

  @@unique([shopId, sku])
  @@unique([shopId, slug])
  @@index([shopId, status, createdAt])
  @@index([siteCategoryId])
  @@index([marketplaceCategoryId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int      @default(0)
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
}

model Customer {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?
  firstName String?
  lastName  String?
  city      String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  dialogues DialogueThread[]
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String?
  status          OrderStatus @default(NEW)
  subtotalAmount  Decimal     @db.Decimal(10, 2)
  deliveryAmount  Decimal     @db.Decimal(10, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal     @db.Decimal(10, 2)
  currency        String      @default("RUB")
  paymentMethod   String?
  paymentStatus   String?
  deliveryMethod  String?
  deliveryPayload Json?
  comment         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    OrderItem[]

  @@index([status, createdAt])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  title      String
  sku        String
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model Review {
  id         String       @id @default(cuid())
  productId  String
  source     ReviewSource
  sourceRef  String?
  rating     Int
  authorName String?
  text       String
  replyText  String?
  status     ReviewStatus @default(NEW)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, source])
  @@index([status, createdAt])
}

model DeliveryMethod {
  id         String             @id @default(cuid())
  code       String             @unique
  title      String
  type       DeliveryMethodType
  isEnabled  Boolean            @default(true)
  configJson Json?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model DialogueChannel {
  id         String   @id @default(cuid())
  code       String   @unique
  title      String
  isEnabled  Boolean  @default(false)
  configJson Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DialogueTemplate {
  id            String   @id @default(cuid())
  title         String
  scope         String
  templateText  String
  variablesJson Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DialogueThread {
  id          String   @id @default(cuid())
  customerId  String?
  channelCode String
  subject     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
}

model FaqEntry {
  id          String   @id @default(cuid())
  question    String
  answer      String
  category    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteTheme {
  id        String   @id @default(cuid())
  shopId    String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, key])
  @@index([shopId])
}

model SiteBanner {
  id        String   @id @default(cuid())
  shopId    String
  key       String
  title     String
  subtitle  String?
  imageUrl  String?
  linkUrl   String?
  position  Int      @default(0)
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, key, position])
}
